{
  "name": "migrate-angular",
  "version": "0.1.0",
  "description": "Incrementally migrate Angular projects from v8 to v20, step by step.",
  "type": "module",
  "bin": {
    "migrate-angular": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run typecheck && npm test && npm run build",
    "pack:preview": "npm pack --dry-run"
  },
  "keywords": [
    "angular",
    "migration",
    "upgrade",
    "cli",
    "ng-update",
    "angular-migration",
    "angular-upgrade"
  ],
  "author": {
    "name": "Srikar Phanikumar Marti",
    "email": "srikar.vamsi@gmail.com",
    "url": "https://github.com/srikarphanikumarmarti"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/srikarphanikumarmarti/migrate-angular.git"
  },
  "bugs": {
    "url": "https://github.com/srikarphanikumarmarti/migrate-angular/issues"
  },
  "homepage": "https://github.com/srikarphanikumarmarti/migrate-angular#readme",
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "commander": "^12.1.0",
    "execa": "^9.3.0",
    "listr2": "^8.2.1",
    "semver": "^7.6.3",
    "ts-morph": "^23.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/cli-progress": "^3.11.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.0",
    "@types/semver": "^7.5.8",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "10.9.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  }
}
